function more(Value) {
  return Value+1; // Value to return
}


function less(Value) {
  return Value-1; // Value to return
}
function add(a,b) {
  return a+b; // Value to return
}

function sub(a,b) {
  return a-b; // Value to return
}
console.log(more(5)); // Should output 6
console.log(less(5)); // Should output 4
console.log(add(5, 3)); // Should output 8
console.log(sub(5, 3)); // Should output 2